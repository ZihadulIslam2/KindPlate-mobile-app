      "item": [
        {
          "name": "Search bookings by business title",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings?page=1&limit=10&title=Salon",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "title",
                  "value": "Salon"
                }
              ]
            },
            "description": "Searches bookings by business title (businessName)."
          },
          "response": []
        },
        {
          "name": "Search bookings by service title",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
